# ============================================================
# TSG Salary Calculator — Backend (Express)
# Copy this file to .env and fill in your values.
# Set these same variables in Vercel → Project Settings → Environment Variables.
# DO NOT commit .env to git.
# ============================================================

# Shared login credentials (one shared account for the whole team)
APP_USERNAME=tsg
APP_PASSWORD=changeme

# Secret used to sign session tokens — use a long random string (32+ chars)
APP_SESSION_SECRET=replace-with-a-long-random-secret-string

# Server port (optional — defaults to 4000 in dev)
# PORT=4000
